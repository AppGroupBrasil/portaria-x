# ═══════════════════════════════════════════
# Portaria X — Environment Variables
# ═══════════════════════════════════════════

# ─── Server ───
PORT=3001
NODE_ENV=development

# JWT Secret — OBRIGATÓRIO em produção, mínimo 32 caracteres aleatórios.
# Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=

# Log level: debug | info | warn | error | silent (default: debug em dev, info em prod)
LOG_LEVEL=
# Log format em produção: JSON por padrão (1 linha por evento). Use "text" para legível.
LOG_FORMAT=

# ─── Database (SQLite) ───
# DB_DIR sobrescreve o diretório do banco. DB_PATH sobrescreve caminho completo.
# Por padrão usa <raiz>/data.db (dev) ou /app/data/data.db (Docker).
DB_DIR=
DB_PATH=
BACKUP_DIR=

# ─── Firebase Cloud Messaging (push notifications) ───
# Caminho do JSON da service account. Por padrão server/firebase-service-account.json.
FIREBASE_CREDENTIALS_PATH=

# ─── Gmail SMTP (Email) ───
# 1. Acesse https://myaccount.google.com/security
# 2. Ative a Verificação em 2 etapas
# 3. Em "Senhas de app" crie uma senha para "Portaria X"
# 4. Cole a senha de 16 caracteres abaixo (sem espaços)
SMTP_USER=seuemail@gmail.com
SMTP_PASS=abcd-efgh-ijkl-mnop
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Portaria X

# App URL (links em emails)
APP_URL=https://portariax.com.br

# ─── AWS SES (alternativa de email, usado em testRoutes) ───
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SES_REGION=sa-east-1
SES_FROM_EMAIL=naoresponda@portariax.com.br
SES_FROM_NAME=Portaria X

# ─── WebSocket "Estou Chegando" (porta standalone se rodar separado) ───
WS_ARRIVAL_PORT=3003

# ═══════════════════════════════════════════
# Frontend (Vite) — prefixadas com VITE_
# ═══════════════════════════════════════════

# URL da API (default: mesma origem)
VITE_API_URL=

# Origem do app para QR codes / links
VITE_APP_ORIGIN=

# Google Maps
VITE_GOOGLE_MAPS_API_KEY=
VITE_GOOGLE_MAPS_MAP_ID=
